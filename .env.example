# Copy to .env for local dev. All optional — defaults run in stub mode.
ENVIRONMENT=development
CORS_ORIGINS=*

# stub (default, no keys) | anthropic | openai
MODEL_PROVIDER=stub

# For the companion tutor + translation via Claude
# ANTHROPIC_API_KEY=sk-ant-...
CHAT_MODEL=claude-sonnet-5

# For translation / TTS via OpenAI (fallback)
# OPENAI_API_KEY=sk-...
TRANSLATION_MODEL=gpt-4o-mini

# Text-to-speech, separate from the text model above.
#   stub  — placeholder bytes (default)
#   local — real Yorùbá voice via facebook/mms-tts-yor (needs requirements-tts.txt)
#   openai— English-only voices
TTS_PROVIDER=stub
LOCAL_TTS_MODEL=facebook/mms-tts-yor
TTS_NUM_THREADS=0

# Where the Ekiti corpus is written (audio + transcripts + corrections)
CORPUS_DIR=data/corpus
